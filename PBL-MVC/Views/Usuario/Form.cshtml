@model PBL_MVC.Models.UsuarioViewModel

@{
    ViewData["Title"] = "Form";
}

<h1>Formulário do Usuário</h1>

@if (ViewBag.Operacao == "I")
{
    <h2>Adicionar Usuário</h2>
    <form asp-controller="Usuario" asp-action="Save" method="post">
        <!-- Inputs para adicionar um usuário -->
        <div class="form-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="IdEmpresa"></label>
            <input asp-for="IdEmpresa" class="form-control" />
            <span asp-validation-for="IdEmpresa" class="text-danger"></span>
        </div>
        <!-- Outros campos -->
        <button type="submit" class="btn btn-primary">Salvar</button>
    </form>
}
else if (ViewBag.Operacao == "A")
{
    <h2>Editar Usuário</h2>
    <form asp-controller="Usuario" asp-action="Save" method="post">
        <!-- Inputs para editar um usuário -->
        <div class="form-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="IdEmpresa"></label>
            <input asp-for="IdEmpresa" class="form-control" />
            <span asp-validation-for="IdEmpresa" class="text-danger"></span>
        </div>
        <!-- Outros campos -->
        <button type="submit" class="btn btn-primary">Salvar</button>
    </form>
}
else if (ViewBag.Operacao == "D")
{
    <h2>Detalhes do Usuário</h2>
    <!-- Exibir detalhes do usuário -->
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>
        <dt class="col-sm-2">Id Empresa</dt>
        <dd class="col-sm-10">@Model.IdEmpresa</dd>
        <!-- Outros campos -->
    </dl>
    <a asp-controller="Usuario" asp-action="Index" class="btn btn-primary">Voltar</a>
}
