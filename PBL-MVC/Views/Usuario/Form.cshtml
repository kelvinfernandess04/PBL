@model PBL_MVC.Models.UsuarioViewModel

@{
    ViewData["Title"] = "Form";
}

<h1>Formulário do Usuário</h1>

@if (ViewBag.Operacao == "I")
{
    <h2>Adicionar Usuário</h2>
    <form asp-controller="Usuario" asp-action="Save" method="post">
        <!-- Inputs para adicionar um usuário -->
        <div class="form-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="IdEmpresa"></label>
            <input asp-for="IdEmpresa" class="form-control" />
            <span asp-validation-for="IdEmpresa" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Cargo"></label>
            <input asp-for="Cargo" class="form-control" />
            <span asp-validation-for="Cargo" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Senha"></label>
            <input asp-for="Senha" class="form-control" />
            <span asp-validation-for="Senha" class="text-danger"></span>
        </div>
        <!-- Outros campos -->
        <button type="submit" class="btn btn-primary">Salvar</button>
    </form>
}
else if (ViewBag.Operacao == "A")
{
    <h2>Editar Usuário</h2>
    <form asp-controller="Usuario" asp-action="Save" method="post">
        <!-- Inputs para editar um usuário -->
        <div class="form-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="IdEmpresa"></label>
            <input asp-for="IdEmpresa" class="form-control" />
            <span asp-validation-for="IdEmpresa" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Cargo"></label>
            <input asp-for="Cargo" class="form-control" />
            <span asp-validation-for="Cargo" class="text-danger"></span>
        </div>
        <!-- Outros campos -->
    <input type="submit" value="Salvar" class="btn btn-primary" />  
        
    </form>
}

