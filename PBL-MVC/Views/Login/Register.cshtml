@model PBL_MVC.Models.UsuarioViewModel

@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Register</h2>

<form asp-action="Register" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label for="Nome">Nome</label>
        <input type="text" class="form-control" id="Nome" name="Nome" required />
    </div>
    <div class="form-group">
        <label for="IdEmpresa">IdEmpresa</label>
        <input type="number" class="form-control" id="IdEmpresa" name="IdEmpresa" required />
    </div>
    <div class="form-group">
        <label for="Cargo">Cargo</label>
        <input type="text" class="form-control" id="Cargo" name="Cargo" required />
    </div>
    <div class="form-group">
        <label for="Senha">Senha</label>
        <input type="password" class="form-control" id="Senha" name="Senha" required />
    </div>
    <div class="form-group">
        <label for="Img">Imagem</label>
        <input type="file" class="form-control" id="ImgFile" onchange="convertImageToBase64(this)" />
        <input type="hidden" id="Img" name="Img" />
    </div>
    <button type="submit" class="btn btn-primary">Registrar</button>
</form>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

@section Scripts {
    <script>
        function convertImageToBase64(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('Img').value = e.target.result.split(',')[1];
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
